{
  "name": "fe",
  "version": "1.0.0",
  "description": "The frontend for LLM-based web application development.",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "test": "vitest run", "demo": "node server/hot-path.js",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "generate": "node generator/index.js ir/kanban-card.ir.json generated-examples/kanban-card/kanban-card.generated.js",
    "generate:kanban": "node generator/app-generator.js contracts/kanban-app.contract.json",
    "generate:dashboard": "node generator/app-generator.js contracts/live-dashboard-app.contract.json",
    "generate:settings": "node generator/app-generator.js contracts/settings-form.contract.json",
    "generate:grid": "node generator/app-generator.js contracts/data-grid.contract.json",
    "generate:catalog": "node generator/app-generator.js contracts/product-catalog.contract.json",
    "generate:ops": "node generator/ops-console-generator.js",
    "test:native": "vitest run --dir test",
    "test:browser": "node gauntlet/apps/normalized-kanban/e2e.node.js",
    "gauntlet": "node gauntlet/run.js",
    "verify:generated": "node generator/verify-generated.js",
    "maturity": "node maturity/update-status.js",
    "prompt": "node bin/prompt.js",
    "chat": "node bin/ask-chatgpt.js",
    "verify:all": "npm run generate:kanban && npm run generate:dashboard && npm run generate:settings && npm run generate:grid && npm run generate:catalog && npm run generate:ops && npm run verify:generated && npm run test:native && npm run test:browser && npm run bench && npm run gauntlet && npm run maturity"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "jsdom": "^29.1.1",
    "puppeteer": "^25.1.0",
    "vitest": "^4.1.9"
  }
}
