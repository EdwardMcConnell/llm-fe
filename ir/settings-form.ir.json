{
  "name": "settings-form",
  "create": {
    "template": "<div data-node=\"root\"><style>:host { display: block; max-width: 600px; margin: 0 auto; padding: 2rem; background: var(--surface-1); border-radius: var(--radius-lg); } h2 { margin-top: 0; color: var(--text-primary); } .form-group { margin-bottom: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; } label { font-weight: 500; color: var(--text-secondary); } .error-message { color: var(--status-error); font-size: 0.875rem; display: none; } .error-message.visible { display: block; } .submit-bar { display: flex; align-items: center; gap: 1rem; margin-top: 2rem; } .submit-spinner { display: none; width: 1.25rem; height: 1.25rem; border: 2px solid var(--text-secondary); border-top-color: transparent; border-radius: 50%; animation: spin 1s linear infinite; } .submit-spinner.visible { display: block; } @keyframes spin { to { transform: rotate(360deg); } }</style><h2>Account Settings</h2><fe-form id=\"settingsForm\"><div class=\"form-group\"><label for=\"usernameInput\">Username</label><input type=\"text\" id=\"usernameInput\" name=\"username\" class=\"fe-input\" required minlength=\"3\"><div id=\"usernameError\" class=\"error-message\" aria-live=\"polite\"></div></div><div class=\"form-group\"><label for=\"emailInput\">Email Address</label><input type=\"email\" id=\"emailInput\" name=\"email\" class=\"fe-input\" required><div id=\"emailError\" class=\"error-message\" aria-live=\"polite\"></div></div><div class=\"form-group\"><label style=\"display:flex; align-items:center; gap:0.5rem; cursor:pointer;\"><input type=\"checkbox\" id=\"notificationsInput\" name=\"notificationsEnabled\">Enable Email Notifications</label></div><div class=\"form-group\"><label for=\"themeInput\">Preferred Theme</label><select id=\"themeInput\" name=\"theme\" class=\"fe-input\"><option value=\"system\">System Default</option><option value=\"light\">Light</option><option value=\"dark\">Dark</option></select></div><div class=\"submit-bar\"><fe-button type=\"submit\" id=\"saveBtn\" variant=\"primary\">Save Changes</fe-button><div id=\"saveSpinner\" class=\"submit-spinner\"></div></div></fe-form></div>",
    "refs": {
      "root": "[data-node=\"root\"]",
      "form": "#settingsForm",
      "usernameInput": "#usernameInput",
      "usernameError": "#usernameError",
      "emailInput": "#emailInput",
      "emailError": "#emailError",
      "notificationsInput": "#notificationsInput",
      "themeInput": "#themeInput",
      "saveBtn": "#saveBtn",
      "saveSpinner": "#saveSpinner"
    }
  },
  "patches": [
    {
      "input": "username",
      "name": "patchUsername",
      "ops": [{ "op": "setInputProperty", "ref": "usernameInput" }]
    },
    {
      "input": "email",
      "name": "patchEmail",
      "ops": [{ "op": "setInputProperty", "ref": "emailInput" }]
    },
    {
      "input": "notificationsEnabled",
      "name": "patchNotifications",
      "ops": [{ "op": "setCheckboxProperty", "ref": "notificationsInput" }]
    },
    {
      "input": "theme",
      "name": "patchTheme",
      "ops": [{ "op": "setInputProperty", "ref": "themeInput" }]
    },
    {
      "input": "usernameError",
      "name": "patchUsernameError",
      "ops": [{ "op": "setTextContent", "ref": "usernameError" }]
    },
    {
      "input": "usernameErrorVisible",
      "name": "patchUsernameErrorVisible",
      "ops": [{ "op": "setClassName", "ref": "usernameError", "trueClass": "error-message visible", "falseClass": "error-message" }]
    },
    {
      "input": "emailError",
      "name": "patchEmailError",
      "ops": [{ "op": "setTextContent", "ref": "emailError" }]
    },
    {
      "input": "emailErrorVisible",
      "name": "patchEmailErrorVisible",
      "ops": [{ "op": "setClassName", "ref": "emailError", "trueClass": "error-message visible", "falseClass": "error-message" }]
    },
    {
      "input": "isSubmitting",
      "name": "patchIsSubmitting",
      "ops": [
        { "op": "setAttribute", "ref": "saveBtn", "attr": "disabled" },
        { "op": "setClassName", "ref": "saveSpinner", "trueClass": "submit-spinner visible", "falseClass": "submit-spinner" }
      ]
    }
  ],
  "events": [
    {
      "name": "Submit",
      "target": "form",
      "type": "submit",
      "emits": "settings:submit",
      "cleanup": true
    },
    {
      "name": "Input",
      "target": "form",
      "type": "input",
      "emits": "settings:input",
      "cleanup": true
    }
  ]
}
