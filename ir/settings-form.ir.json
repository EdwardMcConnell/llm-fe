{
  "name": "settings-form",
  "create": {
    "template": "<div data-node=\"root\"><style>:host { display: block; max-width: 600px; margin: 0 auto; padding: 2rem; background: var(--surface-1); border-radius: var(--radius-lg); } h2 { margin-top: 0; color: var(--text-primary); } .form-group { margin-bottom: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; } label { font-weight: 500; color: var(--text-secondary); } .error-message { color: var(--status-error); font-size: 0.875rem; display: none; } .error-message.visible { display: block; } .submit-bar { display: flex; align-items: center; gap: 1rem; margin-top: 2rem; } .submit-spinner { display: none; width: 1.25rem; height: 1.25rem; border: 2px solid var(--text-secondary); border-top-color: transparent; border-radius: 50%; animation: spin 1s linear infinite; } .submit-spinner.visible { display: block; } @keyframes spin { to { transform: rotate(360deg); } }</style><h2>Account Settings</h2><fe-form id=\"settingsForm\"><div class=\"form-group\"><label for=\"usernameInput\">Username</label><input type=\"text\" id=\"usernameInput\" name=\"username\" class=\"fe-input\" required minlength=\"3\"><div id=\"usernameError\" class=\"error-message\" aria-live=\"polite\"></div></div><div class=\"form-group\"><label for=\"emailInput\">Email Address</label><input type=\"email\" id=\"emailInput\" name=\"email\" class=\"fe-input\" required><div id=\"emailError\" class=\"error-message\" aria-live=\"polite\"></div></div><div class=\"form-group\"><label style=\"display:flex; align-items:center; gap:0.5rem; cursor:pointer;\"><input type=\"checkbox\" id=\"notificationsInput\" name=\"notificationsEnabled\">Enable Email Notifications</label></div><div class=\"form-group\"><label for=\"themeInput\">Preferred Theme</label><select id=\"themeInput\" name=\"theme\" class=\"fe-input\"><option value=\"system\">System Default</option><option value=\"light\">Light</option><option value=\"dark\">Dark</option></select></div><div class=\"submit-bar\"><fe-button type=\"submit\" id=\"saveBtn\" variant=\"primary\">Save Changes</fe-button><div id=\"saveSpinner\" class=\"submit-spinner\"></div></div></fe-form></div>",
    "refs": {
      "root": "[data-node=\"root\"]",
      "form": "#settingsForm",
      "usernameInput": "#usernameInput",
      "usernameError": "#usernameError",
      "emailInput": "#emailInput",
      "emailError": "#emailError",
      "notificationsInput": "#notificationsInput",
      "themeInput": "#themeInput",
      "saveBtn": "#saveBtn",
      "saveSpinner": "#saveSpinner"
    }
  },
  "patches": [
    {
      "input": "username",
      "name": "patchUsername",
      "ops": [
        {
          "op": "setInputProperty",
          "ref": "usernameInput"
        }
      ]
    },
    {
      "input": "email",
      "name": "patchEmail",
      "ops": [
        {
          "op": "setInputProperty",
          "ref": "emailInput"
        }
      ]
    },
    {
      "input": "notificationsEnabled",
      "name": "patchNotifications",
      "ops": [
        {
          "op": "setCheckboxProperty",
          "ref": "notificationsInput"
        }
      ]
    },
    {
      "input": "theme",
      "name": "patchTheme",
      "ops": [
        {
          "op": "setInputProperty",
          "ref": "themeInput"
        }
      ]
    },
    {
      "input": "usernameError",
      "name": "patchUsernameError",
      "ops": [
        {
          "op": "setTextContent",
          "ref": "usernameError"
        }
      ]
    },
    {
      "input": "usernameErrorVisible",
      "name": "patchUsernameErrorVisible",
      "ops": [
        {
          "op": "setClassName",
          "ref": "usernameError",
          "trueClass": "error-message visible",
          "falseClass": "error-message"
        }
      ]
    },
    {
      "input": "emailError",
      "name": "patchEmailError",
      "ops": [
        {
          "op": "setTextContent",
          "ref": "emailError"
        }
      ]
    },
    {
      "input": "emailErrorVisible",
      "name": "patchEmailErrorVisible",
      "ops": [
        {
          "op": "setClassName",
          "ref": "emailError",
          "trueClass": "error-message visible",
          "falseClass": "error-message"
        }
      ]
    },
    {
      "input": "isSubmitting",
      "name": "patchIsSubmitting",
      "ops": [
        {
          "op": "setAttribute",
          "ref": "saveBtn",
          "attr": "disabled"
        },
        {
          "op": "setClassName",
          "ref": "saveSpinner",
          "trueClass": "submit-spinner visible",
          "falseClass": "submit-spinner"
        }
      ]
    }
  ],
  "events": [
    {
      "name": "Submit",
      "target": "form",
      "type": "submit",
      "emits": "settings:submit",
      "cleanup": true
    },
    {
      "name": "Input",
      "target": "form",
      "type": "input",
      "emits": "settings:input",
      "cleanup": true
    }
  ],
  "wireup": {
    "moduleName": "settings-form-app-wireup.generated.js",
    "exportName": "createSettingsApp",
    "rootComponent": "settings-form",
    "appImports": [
      {
        "name": "createSettingsForm",
        "module": "./settings-form.generated.js"
      },
      {
        "name": "createFormSignal",
        "module": "/src/form.js"
      },
      {
        "name": "createEffect",
        "module": "/src/reactivity.js"
      },
      {
        "name": "globalSharedMap",
        "module": "/src/store.js"
      },
      {
        "name": "globalToast",
        "module": "/src/ui.js"
      }
    ],
    "forms": [
      {
        "name": "settings",
        "initialValues": "{ username: '', email: '', notificationsEnabled: false, theme: 'system' }",
        "validate": "(values) => {\n    const errors = {};\n    if (!values.email || !values.email.includes('@')) errors.email = 'A valid email is required.';\n    return errors;\n  }",
        "syncFrom": [
          {
            "field": "username",
            "key": "settings_username"
          },
          {
            "field": "email",
            "key": "settings_email"
          },
          {
            "field": "notificationsEnabled",
            "key": "settings_notifications"
          },
          {
            "field": "theme",
            "key": "settings_theme"
          }
        ]
      }
    ],
    "effects": [
      {
        "code": "const state = getsettingsForm();\n    app.patch({\n      username: state.values.username || '',\n      email: state.values.email || '',\n      notificationsEnabled: !!state.values.notificationsEnabled,\n      theme: state.values.theme || 'system',\n      usernameError: state.errors.username || '',\n      usernameErrorVisible: !!state.errors.username,\n      emailError: state.errors.email || '',\n      emailErrorVisible: !!state.errors.email,\n      isSubmitting: !!state.isSubmitting\n    });"
      }
    ],
    "events": [
      {
        "type": "settings:submit",
        "extract": "ev.sourceEvent.preventDefault();",
        "action": "settingsFormActions.submit(async (values) => {\n         await new Promise(r => setTimeout(r, 600));\n         sharedMap.set('settings_username', values.username);\n         sharedMap.set('settings_email', values.email);\n         sharedMap.set('settings_notifications', values.notificationsEnabled);\n         sharedMap.set('settings_theme', values.theme);\n         globalToast.show('Settings saved successfully', 'success');\n       });"
      },
      {
        "type": "settings:input",
        "extract": "const target = ev.sourceEvent.target;\n       const value = target.type === 'checkbox' ? target.checked : target.value;",
        "action": "settingsFormActions.setFieldValue(target.name, value);"
      }
    ]
  }
}