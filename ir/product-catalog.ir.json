{
  "name": "product-catalog",
  "module": "product-catalog.ir.json",
  "create": {
    "template": "<div data-node=\"root\"><style>:host { display: block; padding: 2rem; background: var(--surface-1); color: var(--text-primary); } .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; } .header h2 { margin: 0; color: var(--brand-primary); } .cart-badge { background: var(--brand-primary); color: var(--text-inverse); padding: 0.25rem 0.75rem; border-radius: 9999px; font-weight: 600; font-size: 0.875rem; } .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 2rem; } .loading-state, .error-state { text-align: center; padding: 4rem; color: var(--text-secondary); }</style><div class=\"header\"><h2>Product Catalog</h2><div class=\"cart-badge\">Cart: <span id=\"cartCount\">0</span></div></div><div id=\"contentArea\"><div id=\"loadingState\" class=\"loading-state\">Loading products...</div><div id=\"errorState\" class=\"error-state\" style=\"display:none;\">Failed to load products.</div><div id=\"productGrid\" class=\"grid\" style=\"display:none;\"></div></div></div>",
    "refs": {
      "root": "[data-node=\"root\"]",
      "cartCount": "#cartCount",
      "loadingState": "#loadingState",
      "errorState": "#errorState",
      "productGrid": "#productGrid"
    }
  },
  "lists": [
    {
      "name": "products",
      "ref": "productGrid",
      "itemKey": "id"
    }
  ],
  "patches": [
    {
      "input": "cartCount",
      "name": "patchCartCount",
      "ops": [
        {
          "op": "setTextContent",
          "ref": "cartCount"
        }
      ]
    },
    {
      "input": "showLoading",
      "name": "patchShowLoading",
      "ops": [
        {
          "op": "setStyleDisplay",
          "ref": "loadingState",
          "trueDisplay": "block",
          "falseDisplay": "none"
        }
      ]
    },
    {
      "input": "showError",
      "name": "patchShowError",
      "ops": [
        {
          "op": "setStyleDisplay",
          "ref": "errorState",
          "trueDisplay": "block",
          "falseDisplay": "none"
        }
      ]
    },
    {
      "input": "showGrid",
      "name": "patchShowGrid",
      "ops": [
        {
          "op": "setStyleDisplay",
          "ref": "productGrid",
          "trueDisplay": "grid",
          "falseDisplay": "none"
        }
      ]
    },
    {
      "input": "productsIndex",
      "name": "patchProductsIndex",
      "ops": [
        {
          "op": "reconcileList",
          "listName": "products"
        }
      ]
    }
  ],
  "events": [],
  "wireup": {
    "moduleName": "product-catalog-app-wireup.generated.js",
    "exportName": "createCatalogApp",
    "rootComponent": "product-catalog",
    "appImports": [
      { "name": "createProductCatalog", "module": "./product-catalog.generated.js" },
      { "name": "createProductCard", "module": "./product-card.generated.js" },
      { "name": "globalSharedMap", "module": "/src/store.js" },
      { "name": "createEffect", "module": "/src/reactivity.js" },
      { "name": "globalDemandManager", "module": "/src/data.js" }
    ],
    "children": [
      { "name": "product", "factory": "createProductCard", "listName": "products" }
    ],
    "setupCode": "const initialCart = sharedMap.get('cart:items') || [];\n  app.patch({ cartCount: initialCart.length });",
    "demand": [
      {
        "name": "Products",
        "key": "catalog:products",
        "fetcher": "async () => {\n    // Mock fetch\n    return new Promise(resolve => {\n      setTimeout(() => {\n        resolve([\n          { id: 'p1', title: 'Ergonomic Keyboard', price: 129.99, img: 'https://placehold.co/400x400/png?text=Keyboard' },\n          { id: 'p2', title: 'Wireless Mouse', price: 59.99, img: 'https://placehold.co/400x400/png?text=Mouse' },\n          { id: 'p3', title: 'Ultra HD Monitor', price: 349.99, img: 'https://placehold.co/400x400/png?text=Monitor' },\n          { id: 'p4', title: 'USB-C Hub', price: 45.00, img: 'https://placehold.co/400x400/png?text=Hub' }\n        ]);\n      }, 50);\n    });\n  }"
      }
    ],
    "effects": [
      {
        "code": "const products = getProducts();\n\n    if (!products) {\n      app.patch({ showLoading: true, showError: false, showGrid: false });\n      return;\n    }\n\n    if (products.error) {\n      app.patch({ showLoading: false, showError: true, showGrid: false });\n      return;\n    }\n\n    app.patch({ showLoading: false, showError: false, showGrid: true });\n\n    const currentIds = products.map(p => p.id);\n    for (const product of products) {\n      patchProduct(product);\n    }\n    \n    app.patch({ productsIndex: currentIds });"
      }
    ],
    "subscriptions": [
      {
        "pattern": "cart:items",
        "matchType": "exact",
        "action": "patchApp",
        "input": "cartCount",
        "valuePath": "length"
      }
    ],
    "events": [
      {
        "type": "catalog:add_to_cart",
        "extract": "const id = ev.sourceEvent.target.closest('[data-node=\"root\"]')?.dataset?.id;\n       if (!id) return;",
        "action": "const currentCart = sharedMap.get('cart:items') || [];\n       sharedMap.set('cart:items', [...currentCart, id]);"
      }
    ]
  },
  "dependencies": [
    "product-card.ir.json"
  ]
}