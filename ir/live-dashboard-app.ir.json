{
  "module": "generated-examples/live-dashboard/live-dashboard-app.generated.js",
  "create": {
    "template": "<div class=\"dashboard-app-root\" data-node=\"root\"><header class=\"dashboard-header\" data-node=\"header\"><h1 class=\"dashboard-title\" data-node=\"title\">Live Telemetry</h1></header><div class=\"dashboard-grid\" data-node=\"grid\"></div></div>",
    "refs": {
      "root": "[data-node=\"root\"]",
      "header": "[data-node=\"header\"]",
      "title": "[data-node=\"title\"]",
      "grid": "[data-node=\"grid\"]"
    }
  },
  "lists": [
    {
      "name": "widgets",
      "itemKey": "id",
      "ref": "grid"
    }
  ],
  "patches": [
    {
      "name": "patchWidgetsIndex",
      "input": "widgetsIndex",
      "ops": [
        {
          "op": "reconcileList",
          "listName": "widgets"
        }
      ]
    }
  ],
  "events": [],
  "wireup": {
    "moduleName": "live-dashboard-app-wireup.generated.js",
    "exportName": "createDashboard",
    "rootComponent": "live-dashboard-app",
    "appImports": [
      {
        "name": "createLiveDashboardApp",
        "module": "./live-dashboard-app.generated.js"
      },
      {
        "name": "createLiveDashboardWidget",
        "module": "./live-dashboard-widget.generated.js"
      }
    ],
    "children": [
      {
        "name": "widget",
        "factory": "createLiveDashboardWidget",
        "listName": "widgets"
      }
    ],
    "subscriptions": [
      {
        "pattern": "dashboard:widget:",
        "matchType": "prefix",
        "action": "patchItem",
        "childName": "widget"
      },
      {
        "pattern": "dashboard:index",
        "matchType": "exact",
        "action": "patchApp",
        "input": "widgetsIndex",
        "valuePath": "itemIds"
      }
    ]
  },
  "dependencies": [
    "live-dashboard-widget.ir.json"
  ],
  "name": "live-dashboard-app"
}