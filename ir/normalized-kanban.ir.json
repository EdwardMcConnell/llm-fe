{
  "module": "generated-examples/normalized-kanban/kanban-app.generated.js",
  "components": [
    {
      "name": "kanban-column",
      "create": {
        "template": "<div class=\"column-root\" data-node=\"root\"><h2 class=\"column-title\" data-node=\"titleNode\"><span class=\"column-count\" data-node=\"countNode\">0</span></h2><div class=\"card-list\" data-node=\"listContainer\"></div></div>",
        "refs": {
          "root": "[data-node=\"root\"]",
          "titleNode": "[data-node=\"titleNode\"]",
          "countNode": "[data-node=\"countNode\"]",
          "listContainer": "[data-node=\"listContainer\"]"
        }
      },
      "patches": [
        {
          "name": "patchStatus",
          "input": "status",
          "ops": [
            {
              "op": "setTextContent",
              "ref": "titleNode"
            },
            {
              "op": "setClassToken",
              "ref": "root",
              "prefix": "column-root column-"
            }
          ]
        }
      ],
      "lists": [
        {
          "name": "cards",
          "ref": "listContainer",
          "itemKey": "id",
          "countRef": "countNode"
        }
      ]
    },
    {
      "name": "kanban-board",
      "create": {
        "template": "<div class=\"board-root\" data-node=\"root\"><div class=\"columns-container\" data-node=\"columnsContainer\"></div></div>",
        "refs": {
          "root": "[data-node=\"root\"]",
          "columnsContainer": "[data-node=\"columnsContainer\"]"
        }
      },
      "children": [
        {
          "name": "todoCol",
          "component": "kanban-column",
          "container": "columnsContainer",
          "staticProps": {
            "status": "todo"
          }
        },
        {
          "name": "inProgressCol",
          "component": "kanban-column",
          "container": "columnsContainer",
          "staticProps": {
            "status": "in-progress"
          }
        },
        {
          "name": "doneCol",
          "component": "kanban-column",
          "container": "columnsContainer",
          "staticProps": {
            "status": "done"
          }
        }
      ]
    }
  ],
  "app": {
    "name": "kanban-app",
    "rootComponent": "kanban-board",
    "customWireups": [
      {
        "source": "generator/wireups/kanban-state.js",
        "target": "kanban-state.generated.js"
      },
      {
        "source": "generator/wireups/kanban-validators.js",
        "target": "kanban-validators.generated.js"
      }
    ]
  },
  "wireup": {
    "moduleName": "kanban-app.generated.js",
    "rootComponent": "createKanbanBoard",
    "exportName": "createKanbanApp",
    "appImports": [
      { "name": "createKanbanBoard", "module": "./kanban-board.generated.js" },
      { "name": "createKanbanCard", "module": "./kanban-card.generated.js" },
      { "name": "applyItemEdit, applyItemMove, applyItemDelete, createInitialBoardState", "module": "./kanban-state.generated.js" },
      { "name": "safeText", "module": "./kanban-validators.generated.js" }
    ],
    "setupCode": "createInitialBoardState(sharedMap);",
    "events": [
      {
        "type": "kanban:item:edit",
        "extract": "const id = ev.sourceEvent.target.dataset.id || ev.sourceEvent.target.closest('[data-id]')?.dataset.id;\n      if (!id) return;",
        "action": "applyItemEdit(sharedMap, id, { title: safeText('Edited Card') });"
      },
      {
        "type": "kanban:item:delete",
        "extract": "const id = ev.sourceEvent.target.closest('[data-node=\"root\"]')?.dataset?.id;\n      if (!id) return;",
        "action": "applyItemDelete(sharedMap, id);"
      },
      {
        "type": "card:dragstart",
        "extract": "const id = ev.sourceEvent.target.closest('[data-node=\"root\"]')?.dataset?.id;\n      if (!id) return;",
        "action": "ev.sourceEvent.dataTransfer.setData('text/plain', id);"
      },
      {
        "type": "kanban:column:reorder",
        "action": "applyItemMove(sharedMap, ev.itemId, ev.fromStatus, ev.toStatus, 999);"
      }
    ],
    "children": [
      { 
        "name": "card", 
        "factory": "createKanbanCard",
        "routeProperty": "status",
        "routeMap": {
          "todo": "todoCol",
          "in-progress": "inProgressCol",
          "done": "doneCol"
        },
        "listName": "cards"
      }
    ],
    "subscriptions": [
      {
        "action": "patchItem",
        "matchType": "prefix",
        "pattern": "kanban:item:",
        "childName": "card"
      },
      {
        "action": "reconcileList",
        "matchType": "prefix",
        "pattern": "kanban:column:",
        "extractKey": "key.split(':')[2]",
        "routeMap": {
          "todo": "todoCol",
          "in-progress": "inProgressCol",
          "done": "doneCol"
        },
        "reconcileList": "cards",
        "valuePath": "itemIds"
      }
    ]
  }
}